rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email in ['alancounihan@gmail.com'];
    }

    // User accounts + profiles subcollection
    match /users/{userId} {
      allow get:   if request.auth != null && request.auth.uid == userId;
      allow list:  if isAdmin();
      allow write: if request.auth != null && request.auth.uid == userId;

      match /profiles/{profileId} {
        allow read:  if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Scores - public read, authenticated write (own data only), admin delete
    match /scores/{scoreId} {
      allow read: if true;
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
                       resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Login events - admin read, any authenticated user can create
    match /loginEvents/{eventId} {
      allow read:   if isAdmin();
      allow create: if request.auth != null;
    }
  }
}
